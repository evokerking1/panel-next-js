# Database — SQLite file path (relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Session secret — must be at least 32 characters, keep this private
SESSION_SECRET="change-this-to-a-random-32-char-string-now"

# Set to "production" for production builds
NODE_ENV="development"

# Set to "true" to force HTTPS for all daemon connections
ENFORCE_DAEMON_HTTPS="false"
