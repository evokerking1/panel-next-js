{
  "name": "airlink",
  "version": "2.0.0-rc1",
  "description": "Airlink is a simple-to-use game server management panel",
  "private": true,
  "scripts": {
    "dev": "npx prisma migrate deploy && npx prisma generate && node -r ts-node/register server.ts",
    "build": "npx prisma generate && next build",
    "start": "npx prisma db push --skip-generate && node -r ts-node/register server.ts",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy && npx prisma generate",
    "lint": "eslint src --fix"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "consola": "^3.4.2",
    "iron-session": "^8.0.3",
    "multer": "^2.0.2",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "validator": "^13.12.0",
    "ws": "^8.14.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.8.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/validator": "^13.12.0",
    "@types/ws": "^8.5.14",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}